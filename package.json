{
  "name": "expo-starter",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "fix": "oxfmt -c config/oxfmt.json --no-error-on-unmatched-pattern && oxlint -c config/oxlint.json --fix && tsc -p config/tsconfig.json --noEmit",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "afterlog": "^1.0.2",
    "expo": "~54.0.33",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.6.2"
  },
  "devDependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "typescript": "^5.9.3"
  }
